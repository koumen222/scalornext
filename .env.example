# ── API Express existante (NE PAS TOUCHER au backend) ──────────────
# Équivalents des anciennes variables VITE_* (voir MIGRATION_LOG.md)
NEXT_PUBLIC_API_URL=https://api.scalor.net
NEXT_PUBLIC_BACKEND_URL=https://api.scalor.net
# Optionnels — mêmes fallbacks que l'app Vite si absents
NEXT_PUBLIC_STORE_API_URL=
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_SCALOR_API_URL=

# ── Auth Google (Login) ─────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ── Analytics ───────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
NEXT_PUBLIC_CUSTOM_ANALYTICS_ENDPOINT=

# ── Version de build (VersionWatcher) — injectée par CI si absente ──
# NEXT_PUBLIC_BUILD_VERSION=
