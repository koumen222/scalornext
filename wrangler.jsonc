{
  "$schema": "node_modules/wrangler/config-schema.json",
  "main": ".open-next/worker.js",
  "name": "scalornext",
  "workers_dev": true,
  "compatibility_date": "2025-06-01",
  "compatibility_flags": [
    // API Node.js (requis par @opennextjs/cloudflare)
    "nodejs_compat",
    "global_fetch_strictly_public"
  ],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "scalornext"
    }
  ],
  "routes": [
    {
      "pattern": "scalor.net/*",
      "zone_name": "scalor.net"
    },
    {
      "pattern": "www.scalor.net/*",
      "zone_name": "scalor.net"
    }
  ],
  "r2_buckets": [
    // Décommenter après avoir créé le bucket R2 (cache ISR durable) :
    // { "binding": "NEXT_INC_CACHE_R2_BUCKET", "bucket_name": "scalor-next-cache" }
  ]
  // Les sous-domaines API et boutiques restent gérés séparément.
}
